# ============================================================================
# .env — 环境变量配置文件
#
# 类似前端的 .env.local 或 .env.development
# 存放"根据环境不同而变化"的配置（端口号、密钥等）
#
# 🔧 为什么要用 .env 而不是直接写在代码里？
#   因为开发环境和生产环境的端口、数据库地址可能不同。
#   写成环境变量，改配置不需要改代码。
# ============================================================================

# FastAPI 服务端口（WebSocket 监听在此端口）
FASTAPI_PORT=8000

# TCP Server 端口（上位机模拟器连接此端口）
TCP_PORT=9000

# TCP Server 监听地址（0.0.0.0 = 接受来自任何 IP 的连接）
TCP_HOST=0.0.0.0

# 🔧 开发环境下推荐用 127.0.0.1（只接受本机连接，更安全）
# TCP_HOST=127.0.0.1
